# 本地开发 SSL 配置示例
# 复制此文件为 .env.local 并填入实际证书路径
#
# 手机局域网测试步骤：
# 1. 从 Porkbun 下载域名的 SSL 证书（cert.pem / key.pem）
# 2. 将证书文件放入 front/.ssl/ 目录
# 3. 复制本文件为 .env.local，按需修改路径
# 4. 重启 Vite dev server：npm run dev
# 5. 手机浏览器访问 https://<电脑局域网IP>:5173

VITE_HTTPS=true
VITE_HOST=0.0.0.0
VITE_SSL_CERT=.ssl/cert.pem
VITE_SSL_KEY=.ssl/key.pem
